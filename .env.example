# Copy to .env.local and fill in your real values. Never commit .env.local.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_BUFFER_API_KEY=YOUR_BUFFER_API_KEY

# Server-side only (set in Vercel -> Settings -> Environment Variables):
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
# Optional, defaults to claude-sonnet-4-5:
# ANTHROPIC_MODEL=claude-sonnet-4-5
